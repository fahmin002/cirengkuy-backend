// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  cooking
  ready
  completed
  cancelled
}

enum PaymentMethod {
  cash
  qris
}

enum DeliveryMethod {
  pickup
  delivery
}

enum ItemType {
  mentah
  matang
}

// Untuk improvement jika ada fitur auth untuk user, sekarang hanya admin saja
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  phone     String?
  role      String   @default("customer") // admin / customer
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Int

  imageUrl String?
  isActive Boolean @default(true)

  stock Int @default(0)

  createdAt DateTime @default(now())

  OrderItem OrderItem[]
}

model Order {
  id   Int    @id @default(autoincrement())
  code String @unique

  // Untuk improvement jika ada fitur auth untuk user, sekarang hanya admin saja
  userId Int?
  User   User? @relation(fields: [userId], references: [id])

  customerName  String
  customerPhone String?

  total Int

  status         OrderStatus    @default(pending)
  paymentMethod  PaymentMethod
  deliveryMethod DeliveryMethod

  address     String?
  scheduledAt DateTime?
  note        String?

  paidAt           DateTime?
  paymentUrl       String?
  paymentExpiredAt DateTime?

  createdAt DateTime @default(now())

  SubOrder  SubOrder[]
  OrderItem OrderItem[]

  @@index([createdAt])
  @@index([status])
}

model SubOrder {
  id      Int @id @default(autoincrement())
  orderId Int

  name String // "Budi", "Andi"
  note String?

  Order     Order       @relation(fields: [orderId], references: [id])
  OrderItem OrderItem[]

  createdAt DateTime @default(now())
}

model OrderItem {
  id         Int  @id @default(autoincrement())
  orderId    Int
  subOrderId Int?

  productId Int
  qty       Int
  price     Int

  type ItemType // mentah | matang
  note String?

  Order    Order     @relation(fields: [orderId], references: [id])
  SubOrder SubOrder? @relation(fields: [subOrderId], references: [id])
  Product  Product   @relation(fields: [productId], references: [id])
}
